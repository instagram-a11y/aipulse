# ─────────────────────────────────────────────────────────────
# AIPulse — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Public site URL (no trailing slash). Use http://localhost:3000 in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Keep this SECRET — server only. Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────
# Developers → API keys (use test keys to start: pk_test_… / sk_test_…)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# From `stripe listen` (dev) or the Dashboard webhook endpoint (prod)
STRIPE_WEBHOOK_SECRET=

# ── Google Calendar / Meet ────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials (OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ── Email (optional) ──────────────────────────────────────────
# Resend API key for the contact form. If empty, messages are logged to the server console.
RESEND_API_KEY=
